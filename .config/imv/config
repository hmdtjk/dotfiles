#
# ~/.config/imv/config
#

[options]
background = 282a36
overlay_text_color = f8f8f2
overlay_position_bottom = true
overlay_background_color = 282a36
overlay_font = Source Code Pro:11
overlay_text = $imv_current_file $imv_width x $imv_height

[binds]
<Shift+Up> = pan 0 -50
<Shift+Down> = pan 0 50
<Shift+Right> = pan 50 0
<Shift+Left> = pan -50 0

<Ctrl+r> = rotate by 90
<Shift+X> = exec rm -v "$imv_current_file"; close
